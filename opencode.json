{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "orchestrator",
    "model": "opencode-go/deepseek-v4-flash",
    "small_model": "minimax-cn-coding-plan/MiniMax-M2.7",
    "autoupdate": "notify",
    "share": "disabled",
    "snapshot": true,
    "lsp": true,
    "formatter": true,
    "permission": {
        "bash": {
            "*": "allow",
            "rm -rf*": "ask",
            "rm -fr*": "ask",
            "git push --force*": "ask",
            "git push -f *": "ask",
            "git reset --hard*": "ask"
        },
        "skill": {
            "*": "allow"
        }
    },
    "plugin": [
        "superpowers@git+https://github.com/obra/superpowers.git",
        "@tarquinen/opencode-dcp@latest"
    ],
    "instructions": [
        "AGENTS.md"
    ],
    "experimental": {
        "batch_tool": true
    },
    "agent": {
        "explore": {
            "model": "opencode-go/deepseek-v4-flash"
        },
        "build": {
            "mode": "primary",
            "model": "minimax-cn-coding-plan/MiniMax-M3",
            "description": "全栈开发代理，所有工具可用。处理实现、调试和一般编码任务。",
            "color": "#E24A4A"
        },
        "plan": {
            "mode": "primary",
            "model": "opencode-go/deepseek-v4-pro",
            "description": "战略规划和分析代理，只读模式。审查代码、设计架构、创建实施计划。",
            "color": "#9B59B6"
        },
        "general": {
            "model": "minimax-cn-coding-plan/MiniMax-M3"
        },
        "title": {
            "model": "opencode-go/deepseek-v4-flash"
        },
        "summary": {
            "model": "opencode-go/deepseek-v4-flash"
        },
        "compaction": {
            "model": "opencode-go/deepseek-v4-flash"
        }
    },
    "compaction": {
        "auto": true,
        "prune": true,
        "tail_turns": 9
    },
    "command": {
        "deep": {
            "description": "Route to deep-worker for heavy implementation",
            "agent": "deep-worker",
            "template": "Handle this task with thoroughness and precision."
        },
        "quick": {
            "description": "Route to light-orchestrator for simple tasks",
            "agent": "light-orchestrator",
            "template": "Handle this task quickly and efficiently."
        },
        "ui": {
            "description": "Route to ui-builder for frontend work",
            "agent": "ui-builder",
            "template": "Build or modify the UI as requested."
        },
        "review": {
            "description": "Route to reviewer for code review",
            "agent": "reviewer",
            "template": "Review the following code thoroughly."
        },
        "plan": {
            "description": "Route to planner for strategic planning",
            "agent": "planner",
            "template": "Create a detailed plan for the following."
        },
        "search": {
            "description": "Route to librarian for external research",
            "agent": "librarian",
            "template": "Research and find information about the following."
        },
        "oracle": {
            "description": "Route to oracle for deep code analysis and root cause debugging",
            "agent": "oracle",
            "template": "Analyze and find the root cause of the following."
        },
        "consult": {
            "description": "Route to consultant for brainstorming and best-practice advice",
            "agent": "consultant",
            "template": "Provide options and advice for the following."
        }
    },
    "mcp": {
        "amap-maps": {
            "type": "remote",
            "url": "https://mcp.amap.com/mcp?key=0d83290b16f270ed936d25914001524f",
            "enabled": false
        }
    }
}
